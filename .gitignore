# Legacy pickle checkpoints — superseded by .skops (pickle executes code on load)
research/models/checkpoints/*.pkl

# 3-class severity RF — research-only (11 MB, regenerable via train_rf.py);
# the package consumes only rf_model.skops
research/models/checkpoints/rf_severity.*

# Personal thesis working notes (not part of the deliverable; some predate the
# 2026-06 group-aware protocol correction and contain superseded numbers)
thesis/MEJORAS_PENDIENTES.md
thesis/memory/
thesis/process-docs/

# ── Pipeline run logs ───────────────────────────────────────────────────────────
research/models/*.log
research/models/retrain_*.log
research/*.log

# ── LaTeX build aux (keep .tex, .bib, .sty, and the final PDF) ──────────────────
thesis/latex/**/*.aux
thesis/latex/*.bbl
thesis/latex/*.blg
thesis/latex/*.log
thesis/latex/*.out
